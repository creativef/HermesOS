# Docker dev environment variables for Hermes Dashboard

# Ports
DASHBOARD_API_PORT=4000
DASHBOARD_WEB_PORT=3000
DATABASE_PORT=5433

# Database (example local URL)
DATABASE_URL=postgres://postgres:postgres@postgres:5432/hermes_dashboard

# Hermes
HERMES_BASE_URL=http://hermes:8642
# Hermes HTTP timeout for Dashboard API -> Hermes requests
HERMES_TIMEOUT_MS=60000
# Hermes timeout for background jobs (message jobs). Longer is normal if Hermes uses browser/tools.
HERMES_JOB_TIMEOUT_MS=600000

# Cost tracking (estimated): set your per-1k token rate in USD (0 disables cost estimation)
COST_PER_1K_TOKENS_USD=0
# Guardrail: treat very short assistant outputs as failures and offer Retry
HERMES_MIN_ASSISTANT_CHARS=20
# Hermes Docker platform (Hermes image may be amd64-only)
#HERMES_PLATFORM=linux/amd64

# App env
NODE_ENV=development

# Feature flags
#FEATURE_EXAMPLE=true
