DATABASE_URL=postgres://postgres:postgres@postgres:5432/hermes_dashboard
HERMES_BASE_URL=http://hermes:8642
# Hermes HTTP timeout for adapter requests
HERMES_TIMEOUT_MS=60000
# Optional admin API key to protect admin and write endpoints
ADMIN_API_KEY=change-me-in-prod

# Cost tracking (estimated): set your per-1k token rate in USD (0 disables cost estimation)
COST_PER_1K_TOKENS_USD=0
